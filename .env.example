# Supabase project values from Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Optional legacy fallback while Supabase projects transition to publishable keys.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only. Do not expose this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME

# Public firm slug seeded by the first migration.
NEXT_PUBLIC_FIRM_SLUG=batalla-associates

# Used for canonical links and auth redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
